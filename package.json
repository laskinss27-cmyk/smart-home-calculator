{
  "name": "smart-home-calculator",
  "version": "2.0.0",
  "description": "Калькулятор оборудования умного дома (Shelly / HitePRO)",
  "main": "dist-electron/main.js",
  "author": "Умный Дом",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.umnydom.calculator",
    "productName": "SmartHomeCalculator",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "artifactName": "SmartHomeCalculator-${version}-win.zip"
  }
}
